# ==========================================
# Client-Side Firebase Configuration
# These are safe to expose to the client.
# Get these from your Firebase Console under Project Settings -> General.
# ==========================================
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# ==========================================
# Server-Side Configuration
# NEVER expose these to the client!
# ==========================================

# 1. Firebase Admin SDK
# Get the JSON object from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Keep this strictly as a single-line stringified JSON or compact JSON object.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# 2. Supabase Configuration
# Used strictly for server-side database/storage access.
# Get these from Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# 3. Groq API Configuration
# Get your API key from Groq Console
GROQ_API_KEY="your-groq-api-key"
# Optional: override the default model (e.g. llama-3.1-70b-versatile)
GROQ_MODEL="llama-3.1-70b-versatile"
